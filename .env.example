# Copie este arquivo para .env e preencha com os valores reais.
# O .env é ignorado pelo git e nunca deve ser commitado.

# Conexão com o banco PostgreSQL usado pelo Prisma (driver pg adapter).
# Aponte para a instância levantada via `docker compose up -d`.
DATABASE_URL="postgresql://oficina_user:oficina_pass@localhost:5432/oficina_db?schema=public"

# Segredo usado para assinar/validar tokens JWT da autenticação administrativa.
# Em dev pode ser uma string longa aleatória; em prod deve vir do gerenciador de segredos.
JWT_SECRET="troque-por-uma-string-longa-e-aleatoria"

# Tempo de expiração do access token. Aceita formatos do `ms` (ex.: "1h", "30m", "7d").
JWT_EXPIRES_IN="1h"

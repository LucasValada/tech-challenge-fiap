# Copie este arquivo para .env e preencha com os valores reais.
# O .env é ignorado pelo git e nunca deve ser commitado.
NODE_ENV="production"
APPLICATION_PORT=3000

# Conexão com o banco PostgreSQL usado pelo Prisma (driver pg adapter).
# Aponte para a instância levantada via `docker compose up -d`.
DATABASE_URL="postgresql://oficina_user:oficina_pass@localhost:5433/oficina_db?schema=public"

# Usado para configurar acesso ao DB
OFICINA_USER="oficina_user"
OFICINA_PASSWORD="oficina_pass"
OFICINA_DB="oficina_db"

# Segredo usado para assinar/validar tokens JWT da autenticação administrativa.
# Em dev pode ser uma string longa aleatória; em prod deve vir do gerenciador de segredos.
JWT_SECRET="troque-por-uma-string-longa-e-aleatoria"

# Tempo de expiração do access token. Aceita formatos do `ms` (ex.: "1h", "30m", "7d").
JWT_EXPIRES_IN="1h"

# Configuração de email (SMTP). Para dev, use Ethereal (https://ethereal.email).
# Crie uma conta em ethereal.email e copie host, port, user e pass.
MAIL_HOST="smtp.ethereal.email"
MAIL_PORT=587
MAIL_USER="seu-usuario@ethereal.email"
MAIL_PASS="sua-senha-ethereal"
MAIL_FROM='"Oficina SOAT" <noreply@oficina.com>'

# Token compartilhado com o sistema externo que envia callbacks de aprovação/recusa
# de orçamento para POST /webhooks/orcamento (header X-Webhook-Token).
# Em prod vem do K8s Secret; em dev gere uma string longa aleatória.
WEBHOOK_ORCAMENTO_TOKEN="troque-por-uma-string-longa-e-aleatoria"
